[sub_resource type="Shader" id="Shader_jgp20"]
code = "// Based on jess::codes https://www.youtube.com/watch?v=eYlBociPwdw and https://www.youtube.com/watch?v=QB2o5Dys6Tc

shader_type canvas_item;

uniform sampler2D overlay: repeat_enable, filter_nearest;
uniform vec4 fg_color : source_color;
uniform vec4 bg_color : source_color;
uniform float tolerance : hint_range(0, 1);

uniform float tile_size = 16.0;
varying vec2 world_position;

void vertex() {
    world_position = (MODEL_MATRIX * vec4(VERTEX, 0.0, 1.0)).xy;
}

void fragment() {
    vec4 curr_color = texture(TEXTURE, UV);

    float dist_bg = distance(curr_color.rgb, bg_color.rgb);
    if (dist_bg <= tolerance) {
        discard;
    }

    vec2 scaled_position = world_position / tile_size;
    vec4 overlay_color = texture(overlay, scaled_position);

    float dist_fg = distance(curr_color.rgb, fg_color.rgb);
    if (dist_fg <= tolerance) {
        COLOR = overlay_color;
    }
}"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_ot0fj"]
shader = SubResource("Shader_jgp20")
shader_parameter/overlay = ExtResource("4_kmpht")
shader_parameter/fg_color = Color(1, 0, 0, 1)
shader_parameter/bg_color = Color(0, 0, 0, 1)
shader_parameter/tolerance = 0.0
shader_parameter/tile_size = 144.0

